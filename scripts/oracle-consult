#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == --diff ]]; then
  shift
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'oracle-consult: --diff must run inside a git repository\n' >&2
    exit 2
  fi
  ref=HEAD
  if (($#)) && git rev-parse --verify "$1^{commit}" >/dev/null 2>&1; then
    ref="$1"
    shift
  fi
  if (($#)); then instruction="$*"; else instruction='Review this diff.'; fi
  diff_stat="$(git diff --stat "$ref" --)"
  diff_file="$(mktemp)"
  git diff "$ref" -- >"$diff_file"
  diff_bytes="$(wc -c <"$diff_file" | tr -d '[:space:]')"
  if ((diff_bytes > 200000)); then
    diff_body="$(head -c 200000 "$diff_file")

[diff truncated at 200 KB — review the rest separately]"
  else
    diff_body="$(cat "$diff_file")"
  fi
  rm -f "$diff_file"
  question="$instruction

Diff stat:
$diff_stat

Diff:
$diff_body"
elif (($#)); then
  question="$*"
else
  question="$(cat)"
fi

if [[ -z "$question" ]]; then
  printf 'oracle-consult: provide a review question or diff description as an argument or stdin\n' >&2
  exit 2
fi

prompt_prefix="$(cat <<'EOF'
You are the Fable 5 oracle acting as a strictly read-only reviewer. Inspect only
with Read, Grep, and Glob. Never edit files, write files, run shell commands, or
perform implementation work. Review the request using repository evidence and
return these sections:
1. verdict: exactly one of approve / approve-with-changes / reject
2. evidence: concise path:line references supporting the verdict
3. ranked risks: highest-risk first, with uncertainty stated explicitly
EOF
)"

prompt="$prompt_prefix

Review request:
$question"

# Read the oracle model from the single source of truth; the native claude CLI
# needs the full model id. Prompt goes via stdin — a positional prompt after
# --tools is swallowed by the flag's variadic parsing.
MODELS="${CLAUDEX_LOCAL_CONFIG_HOME:-$HOME/.config/claudex-local}/models.json"
ORACLE_MODEL="claude-fable-5"
if [[ -f "$MODELS" ]]; then
  ORACLE_MODEL="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["roles"]["oracle"]["model"])' "$MODELS" 2>/dev/null || printf 'claude-fable-5')"
fi

printf '%s' "$prompt" | env -u ANTHROPIC_BASE_URL -u ANTHROPIC_AUTH_TOKEN -u CLAUDE_CONFIG_DIR \
  claude -p --model "$ORACLE_MODEL" --tools Read,Grep,Glob
